# ═══════════════════════════════════════
#  GALACTIC SHIPYARD — Environment Config
#  Copy this to .env and fill in values
# ═══════════════════════════════════════

# Database
DATABASE_URL=postgresql+asyncpg://shipyard:galactic@localhost:5432/galactic_shipyard

# Redis
REDIS_URL=redis://localhost:6379/0

# Security — CHANGE THIS IN PRODUCTION!
SECRET_KEY=galactic-shipyard-ultra-secret-key-change-me

# App
ENVIRONMENT=development
DEBUG=true
